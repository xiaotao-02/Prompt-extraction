{
  "name": "prompt-extracto",
  "version": "0.1.36",
  "description": "Prompt Extracto · 右键任意图片，调用视觉大模型提取 AI 绘画提示词的 Chrome 扩展",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-icons.mjs && vite",
    "build": "node scripts/generate-icons.mjs && tsc --noEmit && vite build",
    "build:watch": "node scripts/generate-icons.mjs && vite build --watch",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "icons:from-image": "powershell -ExecutionPolicy Bypass -File scripts/resize-icons.ps1 && node scripts/optimize-pngs.mjs",
    "zip": "npm run build && node scripts/zip.mjs",
    "package": "npm run zip",
    "release:store": "node scripts/release-store.mjs",
    "store:assets": "node scripts/make-store-assets.mjs",
    "store:screenshots": "node scripts/make-store-screenshots.mjs",
    "install:chrome": "node scripts/install-to-chrome.mjs",
    "install:edge": "node scripts/install-to-chrome.mjs --browser=edge",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.50.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
